# Ignore temporary and editor files
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Ignore local environment files
.env
.env.*

# Ignore editor and IDE settings
.vscode/
.idea/
*.swp
*.swo
*.swn

# Ignore build and dependency artifacts
node_modules/
dist/
build/
coverage/

# Ignore generated browser caches and runtime files
*.tmp
*.temp
*.cache

# Project-specific ignore
.ignore/
